---
// TODO: replace with your real LinkedIn URL
const links = [
  { label: "GitHub", href: "https://github.com/chavanakash/devops-mcp" },
  { label: "LinkedIn", href: "https://linkedin.com/" },
  { label: "Email", href: "mailto:chavanakash2584@gmail.com" },
];
---

<footer id="contact" class="border-t border-[var(--border)] px-6 py-16">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-4 text-center">
    <p class="text-lg font-medium text-[var(--text)]">Let's talk infrastructure.</p>
    <div class="flex gap-6 text-sm text-[var(--text-muted)]">
      {
        links.map((l) => (
          <a href={l.href} target="_blank" rel="noreferrer" class="hover:text-[var(--accent)]">
            {l.label}
          </a>
        ))
      }
    </div>
    <p class="mt-6 text-xs text-[var(--text-muted)]">
      Built with Astro, Kubernetes, Argo CD, and Claude. Source on GitHub.
    </p>
  </div>
</footer>
