aws_region         = "ap-south-1"
aws_profile        = "dockerizzz" # named AWS CLI profile; "" falls back to the default chain
project            = "devops-mcp"
alert_email        = "chavanakash2584@gmail.com"
monthly_budget_usd = "5"
github_repo        = "chavanakash/devops-mcp"

# Off for the first deploy — flip these on later once Datadog/PagerDuty
# accounts exist and DD_API_KEY/DD_APP_KEY/PAGERDUTY_TOKEN are exported.
enable_datadog       = false
enable_pagerduty     = false
pagerduty_user_email = ""
